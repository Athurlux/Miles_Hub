{
  "name": "portifolio",
  "compatibility_date": "2024-11-18",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "pages_build_output_dir": ".vercel/output/static",
  "main": ".vercel/output/static/_worker.js/index.js",
  "assets": {
    "directory": ".vercel/output/static",
    "binding": "ASSETS"
  },
  "observability": {
    "enabled": true
  }
}
